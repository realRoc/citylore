{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "plan_id",
    "title",
    "city",
    "days",
    "nights",
    "source_refs",
    "place_ids",
    "itinerary",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "plan_id": {
      "type": "string",
      "minLength": 3
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "city": {
      "type": "string",
      "minLength": 1
    },
    "days": {
      "type": "integer",
      "minimum": 1
    },
    "profile_id": {
      "type": ["string", "null"]
    },
    "travel_mode": {
      "enum": ["solo", "companion", null]
    },
    "planning_style": {
      "enum": ["classic", "balanced", "local", null]
    },
    "nights": {
      "type": "integer",
      "minimum": 0
    },
    "themes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "place_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "plan_notes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "lodging_anchor": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": ["hotel", "district", "commercial-area", "neighborhood", null]
        },
        "name": {
          "type": ["string", "null"]
        },
        "district": {
          "type": ["string", "null"]
        },
        "source": {
          "enum": ["user", "inferred", null]
        },
        "notes": {
          "type": ["string", "null"]
        }
      }
    },
    "itinerary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["day", "summary", "items"],
        "properties": {
          "day": {
            "type": "integer",
            "minimum": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["slot", "place_id", "name", "category", "reason"],
              "properties": {
                "slot": {
                  "type": "string",
                  "enum": ["morning", "lunch", "afternoon", "dinner", "evening"]
                },
                "place_id": {
                  "type": "string",
                  "minLength": 3
                },
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "district": {
                  "type": ["string", "null"]
                },
                "category": {
                  "type": "string",
                  "minLength": 1
                },
                "duration_min": {
                  "type": ["integer", "null"],
                  "minimum": 15
                },
                "reason": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
